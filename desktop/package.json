{
  "name": "ai-image-workbench",
  "version": "1.0.0",
  "description": "AI 图片筛选与评审工作台",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "build:dir": "electron-builder --win dir",
    "build:nsis": "electron-builder --win nsis"
  },
  "keywords": [],
  "author": "DJM",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.aiimage.workbench",
    "productName": "AI 图片筛选与评审工作台",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "frontend-dist",
        "to": "frontend-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend-dist",
        "to": "backend-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "forceCodeSigning": false,
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI 图片筛选与评审工作台",
      "artifactName": "${productName}-Installer-${version}.${ext}",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}